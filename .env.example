# App
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
DEFAULT_LOCALE=tr

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
AUTH_ALLOW_ENV_FALLBACK=true

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pilot_mvp?schema=public

# Upload limits
UPLOAD_MAX_MB=20

# Email delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=pilot@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=Pilot Tutor <pilot@example.com>

# Queue (Upstash QStash)
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=replace-with-qstash-token

# LLM providers
PRIMARY_MODEL_PROVIDER=openai
PRIMARY_MODEL_NAME=gpt-4o-mini
FALLBACK_MODEL_PROVIDER=anthropic
FALLBACK_MODEL_NAME=claude-3-5-haiku-latest

# Budget policy (locked by pilot scope)
MONTHLY_CAP_USD=10
PER_LESSON_CAP_USD=0.2
BUDGET_MODE_AT_80_PERCENT=short_response_low_cost_model
BUDGET_MODE_AT_100_PERCENT=stop_new_generation_review_only

# Seed users (Phase 2)
SEED_ADMIN_EMAIL=admin@murebbiye.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_STUDENT_EMAIL=student@murebbiye.local
SEED_STUDENT_PASSWORD=ChangeMe123!
SEED_STUDENT_NICKNAME=Pilot Student
SEED_STUDENT_PARENT_EMAIL=parent@example.com
