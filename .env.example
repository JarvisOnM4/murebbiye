# App
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
DEFAULT_LOCALE=tr

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
AUTH_ALLOW_ENV_FALLBACK=true

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/murebbiye?schema=public

# Upload limits
UPLOAD_MAX_MB=20

# Email delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=pilot@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=Pilot Tutor <pilot@example.com>

# Queue (Upstash QStash)
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=replace-with-qstash-token

# LLM providers
PRIMARY_MODEL_PROVIDER=bedrock
PRIMARY_MODEL_NAME=anthropic.claude-3-5-haiku-20241022-v1:0

# AWS Credentials (use IAM role on AWS, env vars for local dev)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Budget policy (locked by pilot scope)
MONTHLY_CAP_USD=10
PER_LESSON_CAP_USD=0.2
BUDGET_MODE_AT_80_PERCENT=short_response_low_cost_model
BUDGET_MODE_AT_100_PERCENT=stop_new_generation_review_only

# Seed users (Phase 2)
SEED_ADMIN_EMAIL=admin@murebbiye.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_STUDENT_EMAIL=student@murebbiye.local
SEED_STUDENT_PASSWORD=ChangeMe123!
SEED_STUDENT_NICKNAME=Pilot Student
SEED_STUDENT_PARENT_EMAIL=parent@example.com

# Media Agent (Phase 8)
MEDIA_BUDGET_PER_LESSON_USD=0.06
MEDIA_AGENT_AUTO_ENRICH=false
MAX_ASSETS_PER_DOCUMENT=10
